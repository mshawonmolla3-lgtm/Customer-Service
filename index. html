<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lazada Dashboard</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
        body { background-color: #f4f4f4; }
        .header { background: #fff; padding: 15px; text-align: center; border-bottom: 2px solid #f57224; }
        #login-page { padding: 40px 20px; text-align: center; }
        .login-box { background: #fff; padding: 30px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); max-width: 400px; margin: auto; }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 5px; outline: none; }
        .btn-main { width: 100%; padding: 12px; background: #f57224; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; }
        #dashboard { display: none; padding: 15px; }
        .profile-section { background: linear-gradient(90deg, #f57224, #ff9d5c); padding: 25px; border-radius: 15px; color: #fff; margin-bottom: 20px; text-align: left; }
        .balance { font-size: 32px; font-weight: bold; margin: 10px 0; }
        .navbar { position: fixed; bottom: 0; width: 100%; background: #fff; display: flex; justify-content: space-around; padding: 12px; border-top: 1px solid #ddd; }
    </style>
</head>
<body>
    <div class="header"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/d/df/Lazada_Logo.svg/1200px-Lazada_Logo.svg.png" width="100"></div>
    <div id="login-page">
        <div class="login-box">
            <h3 style="color:#f57224; margin-bottom:15px;">Sign In</h3>
            <input type="text" placeholder="Phone" value="0582745513">
            <input type="password" placeholder="Password" value="******">
            <button class="btn-main" onclick="showDash()">Login</button>
        </div>
    </div>
    <div id="dashboard">
        <div class="profile-section">
            <p>Total Balance</p>
            <div class="balance">$3,462.18</div>
            <p>Commission: $0.00</p>
        </div>
        <div style="background:#fff; padding:15px; border-radius:10px;">
            <p style="padding:10px 0; border-bottom:1px solid #eee">****7782 <span style="float:right; color:#f57224">$7,410.87</span></p>
            <p style="padding:10px 0;">****6591 <span style="float:right; color:#f57224">$9,993.57</span></p>
        </div>
    </div>
    <div class="navbar" id="nav" style="display:none;"><i class="fa fa-home"></i> <i class="fa fa-list"></i> <i class="fa fa-user"></i></div>
    <script>
        function showDash() {
            document.getElementById('login-page').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            document.getElementById('nav').style.display = 'flex';
        }
    </script>
</body>
</html>
