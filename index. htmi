<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lazada Shopping</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: sans-serif; }
        body { background-color: #f4f4f4; }
        .header { background: #fff; padding: 10px; text-align: center; border-bottom: 2px solid #f57224; }
        .login-box { background: #fff; padding: 25px; border-radius: 10px; max-width: 350px; margin: 50px auto; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 5px; }
        .btn-main { width: 100%; padding: 12px; background: #f57224; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; }
        #dashboard { display: none; padding: 15px; }
        .profile-card { background: linear-gradient(90deg, #f57224, #ff9d5c); padding: 20px; border-radius: 15px; color: #fff; }
        .balance { font-size: 30px; font-weight: bold; margin: 10px 0; }
        .nav-bar { position: fixed; bottom: 0; width: 100%; background: #fff; display: flex; justify-content: space-around; padding: 10px; border-top: 1px solid #ddd; }
    </style>
</head>
<body>
    <div class="header">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/d/df/Lazada_Logo.svg/1200px-Lazada_Logo.svg.png" width="100">
    </div>

    <div id="login-page">
        <div class="login-box">
            <h3 style="color:#f57224">Login</h3>
            <input type="text" placeholder="Username" value="0582745513">
            <input type="password" placeholder="Password" value="******">
            <button class="btn-main" onclick="enterDash()">Sign in</button>
        </div>
    </div>

    <div id="dashboard">
        <div class="profile-card">
            <p>Account balance</p>
            <div class="balance">$3,462.18</div>
            <p>Today's profit: $0.00</p>
        </div>
        <div style="margin-top:20px; background:#fff; padding:15px; border-radius:10px;">
            <h4>Recent Commission</h4>
            <p style="padding:10px 0; border-bottom:1px solid #eee">****7782 <span style="float:right; color:#f57224">$7,410.87</span></p>
            <p style="padding:10px 0;">****6591 <span style="float:right; color:#f57224">$9,993.57</span></p>
        </div>
    </div>

    <div class="nav-bar" id="bottom-nav" style="display:none">
        <i class="fa fa-home"></i>
        <i class="fa fa-list"></i>
        <i class="fa fa-shopping-cart"></i>
        <i class="fa fa-user"></i>
    </div>

    <script>
        function enterDash() {
            document.getElementById('login-page').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            document.getElementById('bottom-nav').style.display = 'flex';
        }
    </script>
</body>
</html>
